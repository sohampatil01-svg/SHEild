<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".ui.FakeCallActivity">

    <!-- === ANDROID SKIN (Google Dialer Style) === -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutAndroid"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#1A1C1E"
        android:visibility="visible">

        <TextView
            android:id="@+id/tvAndroidName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dad"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:layout_marginTop="100dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvAndroidStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calling..."
            android:textColor="#C4C7C5"
            android:textSize="18sp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvAndroidName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Incoming controls -->
        <LinearLayout
            android:id="@+id/groupAndroidIncoming"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="100dp"
            app:layout_constraintBottom_toBottomOf="parent">
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabAndroidDecline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="60dp"
                app:backgroundTint="#FF453A"
                app:srcCompat="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#FFFFFF"
                app:elevation="0dp"/>
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabAndroidAnswer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="60dp"
                app:backgroundTint="#32D74B"
                app:srcCompat="@android:drawable/ic_menu_call"
                app:tint="#FFFFFF"
                app:elevation="0dp"/>
        </LinearLayout>

        <!-- REALISTIC ANDROID IN-CALL GRID -->
        <GridLayout
            android:id="@+id/groupAndroidInCall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="2"
            android:paddingHorizontal="30dp"
            android:visibility="gone"
            android:layout_marginBottom="180dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Mute -->
            <LinearLayout android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:padding="10dp">
                <ImageView android:layout_width="56dp" android:layout_height="56dp" android:padding="14dp" android:background="@drawable/bg_call_btn" android:src="@android:drawable/ic_lock_silent_mode" app:tint="#FFFFFF"/>
                <TextView android:text="mute" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <!-- Keypad -->
            <LinearLayout android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:padding="10dp">
                <ImageView android:layout_width="56dp" android:layout_height="56dp" android:padding="14dp" android:background="@drawable/bg_call_btn" android:src="@android:drawable/ic_dialog_dialer" app:tint="#FFFFFF"/>
                <TextView android:text="keypad" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <!-- Speaker -->
            <LinearLayout android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:padding="10dp">
                <ImageView android:layout_width="56dp" android:layout_height="56dp" android:padding="14dp" android:background="@drawable/bg_call_btn" android:src="@android:drawable/ic_lock_silent_mode_off" app:tint="#FFFFFF"/>
                <TextView android:text="speaker" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <!-- Add Call -->
            <LinearLayout android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:padding="10dp">
                <ImageView android:layout_width="56dp" android:layout_height="56dp" android:padding="14dp" android:background="@drawable/bg_call_btn" android:src="@android:drawable/ic_menu_add" app:tint="#FFFFFF"/>
                <TextView android:text="add call" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <!-- Video Call -->
            <LinearLayout android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:padding="10dp">
                <ImageView android:layout_width="56dp" android:layout_height="56dp" android:padding="14dp" android:background="@drawable/bg_call_btn" android:src="@android:drawable/ic_menu_camera" app:tint="#FFFFFF"/>
                <TextView android:text="video call" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <!-- Contacts -->
            <LinearLayout android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:padding="10dp">
                <ImageView android:layout_width="56dp" android:layout_height="56dp" android:padding="14dp" android:background="@drawable/bg_call_btn" android:src="@android:drawable/ic_menu_myplaces" app:tint="#FFFFFF"/>
                <TextView android:text="contacts" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </GridLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnAndroidEndCall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="60dp"
            android:visibility="gone"
            app:backgroundTint="#FF453A"
            app:srcCompat="@android:drawable/ic_menu_call"
            app:tint="#FFFFFF"
            android:rotation="135"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- === iOS SKIN (Apple Style) === -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutIos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#1C1C1E"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvIosName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dad"
            android:textColor="#FFFFFF"
            android:textSize="38sp"
            android:layout_marginTop="100dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvIosStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="mobile"
            android:textColor="#8E8E93"
            android:textSize="20sp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvIosName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- iOS Incoming Controls -->
        <LinearLayout
            android:id="@+id/groupIosIncoming"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="100dp"
            app:layout_constraintBottom_toBottomOf="parent">
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabIosDecline"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginEnd="60dp"
                app:backgroundTint="#FF3B30"
                app:srcCompat="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#FFFFFF"
                app:fabCustomSize="72dp"
                app:elevation="0dp"/>
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabIosAnswer"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginStart="60dp"
                app:backgroundTint="#34C759"
                app:srcCompat="@android:drawable/ic_menu_call"
                app:tint="#FFFFFF"
                app:fabCustomSize="72dp"
                app:elevation="0dp"/>
        </LinearLayout>

        <!-- REALISTIC iOS IN-CALL GRID -->
        <GridLayout
            android:id="@+id/groupIosInCall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="2"
            android:paddingHorizontal="40dp"
            android:visibility="gone"
            android:layout_marginBottom="200dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:padding="12dp">
                <ImageView android:layout_width="64dp" android:layout_height="64dp" android:padding="18dp" android:background="@drawable/bg_call_btn" android:src="@android:drawable/ic_lock_silent_mode" app:tint="#FFFFFF"/>
                <TextView android:text="mute" android:textColor="#FFFFFF" android:textSize="13sp" android:layout_marginTop="6dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:padding="12dp">
                <ImageView android:layout_width="64dp" android:layout_height="64dp" android:padding="18dp" android:background="@drawable/bg_call_btn" android:src="@android:drawable/ic_dialog_dialer" app:tint="#FFFFFF"/>
                <TextView android:text="keypad" android:textColor="#FFFFFF" android:textSize="13sp" android:layout_marginTop="6dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:padding="12dp">
                <ImageView android:layout_width="64dp" android:layout_height="64dp" android:padding="18dp" android:background="@drawable/bg_call_btn" android:src="@android:drawable/ic_lock_silent_mode_off" app:tint="#FFFFFF"/>
                <TextView android:text="speaker" android:textColor="#FFFFFF" android:textSize="13sp" android:layout_marginTop="6dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:padding="12dp">
                <ImageView android:layout_width="64dp" android:layout_height="64dp" android:padding="18dp" android:background="@drawable/bg_call_btn" android:src="@android:drawable/ic_menu_add" app:tint="#FFFFFF"/>
                <TextView android:text="add call" android:textColor="#FFFFFF" android:textSize="13sp" android:layout_marginTop="6dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:padding="12dp">
                <ImageView android:layout_width="64dp" android:layout_height="64dp" android:padding="18dp" android:background="@drawable/bg_call_btn" android:src="@android:drawable/ic_menu_camera" app:tint="#FFFFFF"/>
                <TextView android:text="FaceTime" android:textColor="#FFFFFF" android:textSize="13sp" android:layout_marginTop="6dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:padding="12dp">
                <ImageView android:layout_width="64dp" android:layout_height="64dp" android:padding="18dp" android:background="@drawable/bg_call_btn" android:src="@android:drawable/ic_menu_myplaces" app:tint="#FFFFFF"/>
                <TextView android:text="contacts" android:textColor="#FFFFFF" android:textSize="13sp" android:layout_marginTop="6dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </GridLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnIosEndCall"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginBottom="70dp"
            android:visibility="gone"
            app:backgroundTint="#FF3B30"
            app:srcCompat="@android:drawable/ic_menu_call"
            app:tint="#FFFFFF"
            android:rotation="135"
            app:fabCustomSize="72dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:elevation="0dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
